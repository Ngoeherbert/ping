# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host.neon.tech/pingdb?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-min-32-chars
BETTER_AUTH_URL=http://localhost:8081

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Expo
# Use a reachable URL for physical devices (for example your tunnel/LAN URL), not localhost.
EXPO_PUBLIC_API_URL=http://localhost:8081
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Storage (for media uploads — e.g. Cloudinary or S3)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=ping_uploads

# Public profile links
EXPO_PUBLIC_PROFILE_BASE_URL=https://ping.app/u
