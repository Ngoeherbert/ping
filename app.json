{
  "expo": {
    "name": "Ping",
    "slug": "ping",
    "scheme": "ping",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Ping needs camera access to create posts."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Ping needs photo library access."
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "apiUrl": "http://localhost:8081",
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
